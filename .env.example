# ============================================
# Dedup File Storage Engine - Environment Config
# ============================================

# Server
PORT=3000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/dedup_engine

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# Storage
CHUNK_STORAGE_PATH=./storage/chunks
TEMP_UPLOAD_PATH=./uploads

# Chunking — size of each chunk in bytes (default 1 MB)
CHUNK_SIZE_BYTES=1048576

# Logging
LOG_LEVEL=debug
